{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/.next",
			"!**/dist",
			"!*.lockb",
			"!bun.lock",
			"!**/*.css"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"overrides": [
		{
			"includes": ["apps/strava-boost/**"],
			"linter": {
				"rules": {
					"a11y": {
						"useButtonType": "off",
						"noSvgWithoutTitle": "off",
						"noStaticElementInteractions": "off",
						"useKeyWithClickEvents": "off",
						"noLabelWithoutControl": "off"
					},
					"correctness": {
						"useExhaustiveDependencies": "off",
						"noUnusedVariables": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					},
					"suspicious": {
						"noRedeclare": "off"
					}
				}
			}
		}
	]
}
