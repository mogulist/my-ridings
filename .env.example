# Supabase 설정 (Vercel Marketplace에서 Supabase 생성 시 자동 설정됨)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 프로덕션 어드민 리다이렉트용 (admin 배포 시 필수)
# - OAuth 로그인 시 redirectTo, 콜백/로그아웃 리다이렉트에 사용
# - 예: NEXT_PUBLIC_SITE_URL=https://admin.kfondo.cc
#
# ⚠️ Supabase 대시보드 설정도 필수 (그렇지 않으면 GitHub 로그인 후 localhost로 리다이렉트됨):
#    Authentication > URL Configuration >
#    - Site URL: https://admin.kfondo.cc (프로덕션 도메인)
#    - Redirect URLs: https://admin.kfondo.cc/admin/auth/callback 추가
# NEXT_PUBLIC_SITE_URL=https://admin.kfondo.cc

# 공개 사이트 canonical URL (Disqus 등, 사용자에게 보이는 도메인)
# NEXT_PUBLIC_PUBLIC_SITE_URL=https://www.kfondo.cc

# 마이그레이션 스크립트용 (Service Role Key - 절대 클라이언트에 노출 금지)
# Supabase Dashboard > Settings > API에서 확인
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 네이버맵 (2단계 코스 지도) - Naver Cloud Platform Maps Client ID
# NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=your-ncp-client-id

# Vercel Blob (GPX 업로드) - Vercel Storage에서 Blob 스토어 생성 시 자동 설정
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Race Result 크롤러 (선택) — 공개 config에 key가 있으면 생략 가능
# RACERESULT_KEY=
# RACERESULT_LIST_HOST=my-hk-1.raceresult.com
