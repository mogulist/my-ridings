{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "debug": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "installCommand": "cd ../.. && bun install --frozen-lockfile"
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "installCommand": "cd ../.. && bun install --frozen-lockfile"
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "installCommand": "cd ../.. && bun install --frozen-lockfile"
    }
  }
}
