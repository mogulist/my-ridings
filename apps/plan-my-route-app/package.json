{
  "name": "plan-my-route-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "eas-build-pre-install": "cd ../.. && bun install --frozen-lockfile",
    "start": "expo start",
    "start:clean": "expo start -c",
    "start:debug": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "build:debug:ios": "eas build --profile debug --platform ios",
    "build:debug:ios:local": "eas build --profile debug --platform ios --local",
    "build:debug:android": "eas build --profile debug --platform android",
    "build:debug:android:local": "eas build --profile debug --platform android --local",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:ios:local": "eas build --profile preview --platform ios --local",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:preview:android:local": "eas build --profile preview --platform android --local",
    "build:production:ios": "eas build --profile production --platform ios",
    "build:production:ios:local": "eas build --profile production --platform ios --local",
    "build:production:android": "eas build --profile production --platform android",
    "build:production:android:local": "eas build --profile production --platform android --local",
    "submit:production:ios": "eas submit --platform ios --profile production --latest"
  },
  "dependencies": {
    "@mj-studio/react-native-naver-map": "^2.7.1",
    "@my-ridings/plan-geometry": "workspace:*",
    "@my-ridings/weather-types": "workspace:*",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/react-query": "^5.99.2",
    "expo": "~55.0.12",
    "expo-auth-session": "~7.0.10",
    "expo-build-properties": "^55.0.12",
    "expo-constants": "~55.0.12",
    "expo-crypto": "~15.0.7",
    "expo-dev-client": "^55.0.23",
    "expo-device": "~55.0.13",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-haptics": "^55.0.14",
    "expo-image": "~55.0.8",
    "expo-keep-awake": "~55.0.6",
    "expo-linking": "~55.0.11",
    "expo-location": "~55.1.8",
    "expo-router": "~55.0.11",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~55.0.16",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.14",
    "expo-web-browser": "~55.0.13",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
