{
  "expo": {
    "name": "plan-my-route-app",
    "slug": "plan-my-route-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "planmyrouteapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.herbertlim.planmyrouteapp",
      "appleTeamId": "HJQ38R7WDY",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "라이딩 중 현재 위치를 경로에 표시하기 위해 위치 권한이 필요합니다."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.herbertlim.planmyrouteapp",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "라이딩 중 현재 위치를 경로에 표시하기 위해 위치 권한이 필요합니다.",
          "locationWhenInUsePermission": "라이딩 중 현재 위치를 경로에 표시하기 위해 위치 권한이 필요합니다.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bc93fbce-8ebd-4e28-9109-50ae6c6462b0"
      }
    }
  }
}
